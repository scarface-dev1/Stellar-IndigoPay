PORT=4000
NODE_ENV=development
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
ALLOWED_ORIGINS=https://indigopay.app,https://www.indigopay.app,https://stellar-indigopay.app,https://www.stellar-indigopay.app,http://localhost:3000,http://127.0.0.1:3000
CONTRACT_ID=
DATABASE_URL=postgres://postgres:postgres@localhost:5432/indigopay

# Redis — caching layer for project list and stats (60-second TTL)
# Omit or leave blank to run without Redis (cache is silently bypassed)
REDIS_URL=redis://localhost:6379

# Transactional email — get a free API key at https://resend.com
RESEND_API_KEY=
EMAIL_FROM=IndigoPay <updates@yourdomain.com>
APP_URL=http://localhost:3000

# JWT secret for admin authentication (generate with: openssl rand -hex 32)
JWT_SECRET=

# Admin login credentials (used by POST /api/admin/login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Anthropic Claude API — required for AI project summaries
ANTHROPIC_API_KEY=

# PostgreSQL connection pool tuning
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECT_TIMEOUT=2000

# Verification Request admin notification (defaults to EMAIL_FROM)
# Used by /api/verification-requests to email admins on new submissions.
ADMIN_NOTIFICATION_EMAIL=

# Document upload backend for the /apply form.
#   local   – writes to ./uploads and serves them at GET /api/uploads/:key.
#   s3      – requires AWS_REGION/AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY/S3_BUCKET.
#   ipfs    – requires IPFS_API_URL (HTTP /api/v0/add endpoint).
# Unknown/missing-credential configurations silently fall back to "local".
STORAGE_BACKEND=local
UPLOAD_MAX_BYTES=10485760

# S3 (only used when STORAGE_BACKEND=s3)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_URL=

# IPFS (only used when STORAGE_BACKEND=ipfs)
IPFS_API_URL=
IPFS_GATEWAY_URL=https://ipfs.io/ipfs
