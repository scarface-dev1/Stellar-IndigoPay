{
  "manifest_version": 3,
  "name": "IndigoPay Companion",
  "version": "1.0.0",
  "description": "Support your favorite sustainable projects with a single click.",
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "IndigoPay Companion"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "background": {
    "scripts": ["dist-firefox/background.js"]
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist-firefox/content-script.js"],
      "run_at": "document_end"
    }
  ],
  "privacy_policy_url": "https://github.com/Stellar-IndigoPay/Stellar-IndigoPay/blob/main/PRIVACY.md",
  "browser_specific_settings": {
    "gecko": {
      "id": "indigopay@stellar-indigopay.com",
      "strict_min_version": "120.0"
    }
  }
}
